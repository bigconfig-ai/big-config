{:deps {io.github.amiorin/redis {:local/root "."}}
 :tasks
 {:requires ([io.github.amiorin.redis.describe :as describe]
             [io.github.amiorin.redis.options :as options]
             [io.github.amiorin.redis.package :as package]
             [io.github.amiorin.redis.tools :as tools]
             [io.github.amiorin.redis.validation :as validation])
  help {:doc "the workflow help"
        :override-builtin true
        :task (println "Usage: bb <task> [args...]

Tasks:
  redis      Provision or tear down compute for the active profile.
            Usage:
              bb redis create          Run the create pipeline:
                                                  tofu -> ansible-local -> ansible
              bb redis delete          Destroy the Tofu compute stage.
              bb redis delete create   Clean-slate redeploy.
            Notes:
              * Compute resources render with prevent_destroy = true by default.
                Override with:
                  BC_PAR_COMPUTE_PREVENT_DESTROY=false bb redis delete
              * The active profile is selected by (def bb ...) in options.clj.

  validate  Pre-flight checks for the active profile. Verifies:
              * profile params
              * required CLIs are installed
              * cloud credentials are present
              * :compute-pubkey is loaded in ssh-agent for cloud compute profiles
            Usage:
              bb validate

  describe  Show selected providers, compute IP, and SSH reachability for the
            active profile.
            Usage:
              bb describe

  tofu      Render/run the compute OpenTofu tool workflow.
            Usage:
              bb tofu render tofu:init tofu:apply:-auto-approve

  ansible-local
            Render/run the local ping playbook.
            Usage:
              bb ansible-local render -- ansible-playbook main.yml

  ansible   Render/run the remote ping playbook.
            Usage:
              bb ansible render -- ansible-playbook main.yml

  tidy      Tidy Clojure files.
            Usage:
              bb tidy

See:
* https://www.bigconfig.ai/manual")}
  tidy {:doc "tidy clojure files"
        :task (do (shell "clojure-lsp clean-ns")
                  (shell "clojure-lsp format"))}
  validate {:doc "validate active profile params, tools, credentials, and ssh-agent"
            :task (validation/validate* *command-line-args* options/bb)}
  describe {:doc "describe selected providers, compute IP, and SSH reachability"
            :override-builtin true
            :task (describe/describe* *command-line-args* options/bb)}
  tofu {:doc "bb tofu render tofu:init tofu:apply:-auto-approve"
        :task (tools/tofu* *command-line-args* (package/redis-opts options/bb))}
  ansible-local {:doc "bb ansible-local render -- ansible-playbook main.yml"
                 :task (tools/ansible-local* *command-line-args* (package/redis-opts options/bb))}
  ansible {:doc "bb ansible render -- ansible-playbook main.yml"
           :task (tools/ansible* *command-line-args* (package/redis-opts options/bb))}
  redis {:doc "bb redis create | bb redis delete"
                    :task (package/redis* *command-line-args* options/bb)}}}
